{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "百宝箱",
  "version": "0.1.0",
  "identifier": "com.baibao.toolbox",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1860",
    "beforeDevCommand": "pnpm dev:web",
    "beforeBuildCommand": "pnpm build:web"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "百宝箱",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
