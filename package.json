{
  "name": "baibao-toolbox",
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "tauri dev",
    "dev:web": "vite",
    "dist": "tauri build",
    "build:web": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "dist:ios": "APPLE_DEVELOPMENT_TEAM=J4JFUVCFB4 tauri ios build --export-method debugging",
    "install:ios": "pnpm dist:ios && bash scripts/ios-install.sh",
    "dist:android": "tauri android build --apk --debug",
    "install:android": "pnpm dist:android && bash scripts/android-install.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "react": "^18",
    "react-dom": "^18"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@vitejs/plugin-react": "^4",
    "esbuild": "^0.28.0",
    "typescript": "^5",
    "vite": "^5"
  }
}
